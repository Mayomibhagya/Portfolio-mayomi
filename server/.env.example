# Server Environment Variables
NODE_ENV=development
PORT=5000

# MongoDB Connection
MONGODB_URI=your_mongodb_connection_string

# JWT Configuration
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRE=1h

# Security
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=https://your-portfolio-domain.example.com,https://www.your-portfolio-domain.example.com,http://localhost:5173
CORS_ORIGIN=https://your-portfolio-domain.example.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=600000  # 10 minutes
RATE_LIMIT_MAX_REQUESTS=700

# Logging
LOG_LEVEL=debug  # 'error', 'warn', 'info', 'debug'

# Admin Account (for initial setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password

# Email Configuration for Password Reset
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_smtp_username
EMAIL_PASSWORD=your_smtp_password
EMAIL_FROM=your_email@example.com
PASSWORD_RESET_EXPIRY=15  # 15 minutes (integer value only, model will convert to ms)

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=portfolio
