# Client Environment Variables

# API Configuration
# VITE_API_URL=https://your-production-api.example.com/api
VITE_API_URL=http://localhost:5000/api

# Integration Keys
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
VITE_GA_MEASUREMENT_ID=your_google_analytics_id

# Portfolio URL
VITE_PORTFOLIO_URL=https://your-portfolio-domain.example.com

# Social Media URLs
VITE_GITHUB_URL=https://github.com/your-username
VITE_LINKEDIN_URL=https://linkedin.com/in/your-profile
VITE_FACEBOOK_URL=https://www.facebook.com/your-profile
VITE_INSTAGRAM_URL=https://www.instagram.com/your-profile
VITE_WHATSAPP_URL=https://wa.me/your_phone_number
VITE_PHONE_NUMBER=your_phone_number

# Theme settings
VITE_DEFAULT_THEME=dark

# Feature flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_PWA=false
VITE_SHOW_DEV_BANNER=false

# Password Reset
VITE_PASSWORD_RESET_EXPIRY=15
